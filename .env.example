# LLM — default is Google AI Studio (Gemini 2.5). Grok optional via LLM_PROVIDER=grok
# Gemini: https://aistudio.google.com/apikey — free tier includes Flash-Lite / Flash / Pro (see AI Studio for RPD)
GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=
# Examples: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash-lite

# xAI Grok (optional): https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
# GROK_MODEL=grok-4-1-fast-non-reasoning

# Force provider: gemini | grok (if unset: Gemini when GOOGLE_API_KEY is set, else Grok if XAI only)
# LLM_PROVIDER=gemini

# Other LLM keys (optional — not used by linkedin_job_agent graph)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_key_here

# LangSmith for tracing and monitoring (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=linkedin-job-agent

# LinkedIn User Profile (required for profile fetching and personalization)
LINKEDIN_USER_HANDLE=your-linkedin-handle
# Example: If your profile is linkedin.com/in/john-doe, use: john-doe

# LinkedIn credentials — required for Easy Apply automation
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
# Your phone number for Easy Apply contact forms
PHONE_NUMBER=4439294371

# Application settings
DEBUG=false
LOG_LEVEL=INFO

# Database (optional - for persistence)
# MONGODB_URI=mongodb://localhost:27017/linkedin_agent
# POSTGRES_URL=postgresql://user:password@localhost:5432/linkedin_agent

# Rate limiting
MAX_APPLICATIONS_PER_DAY=50
SEARCH_RATE_LIMIT_PER_MINUTE=10